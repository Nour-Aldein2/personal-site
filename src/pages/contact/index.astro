---
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { absoluteSiteUrl, sitePath, siteSettings } from "../../lib/site";

const contactFormAction = import.meta.env.PUBLIC_CONTACT_FORM_ACTION;

const contactSchema = [
  {
    "@context": "https://schema.org",
    "@type": "ContactPage",
    name: `Contact | ${siteSettings.authorName}`,
    description: `Contact ${siteSettings.authorName} about AI engineering, research, publications, or collaboration.`,
    url: absoluteSiteUrl("/contact/", Astro.site),
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      {
        "@type": "ListItem",
        position: 1,
        name: "Home",
        item: absoluteSiteUrl("/", Astro.site),
      },
      {
        "@type": "ListItem",
        position: 2,
        name: "Contact",
        item: absoluteSiteUrl("/contact/", Astro.site),
      },
    ],
  },
];
---

<BaseLayout
  title={`Contact | ${siteSettings.authorName}`}
  description={`Contact ${siteSettings.authorName} about AI engineering, research, publications, technical writing, or collaboration.`}
  canonicalPath="/contact/"
  ogType="website"
  image={siteSettings.authorImage}
  schema={contactSchema}
>
  <div class="shell">
    <Breadcrumbs
      items={[
        { label: "Home", href: "/" },
        { label: "Contact" },
      ]}
    />

    <section class="page-intro">
      <p class="eyebrow">Contact</p>
      <h1>Get in touch</h1>
      <p>
        Use this form for research collaboration, AI engineering work, publications,
        technical writing, or speaking inquiries. Your message can be forwarded without
        exposing a public email address on the site.
      </p>
    </section>

    <section class="page-section">
      <section class="content-card contact-card">
        <form
          class="contact-form"
          name="contact"
          method="POST"
          action={contactFormAction || sitePath("contact/success/")}
          data-netlify={contactFormAction ? undefined : "true"}
          netlify-honeypot={contactFormAction ? undefined : "company_website"}
        >
          {!contactFormAction && <input type="hidden" name="form-name" value="contact" />}
          <input
            type="text"
            name="company_website"
            class="hp-field"
            tabindex="-1"
            autocomplete="off"
          />

          <label class="form-field">
            <span>Name</span>
            <input type="text" name="name" autocomplete="name" required />
          </label>

          <label class="form-field">
            <span>Email</span>
            <input type="email" name="email" autocomplete="email" required />
          </label>

          <label class="form-field">
            <span>Subject</span>
            <input type="text" name="subject" required />
          </label>

          <label class="form-field">
            <span>Message</span>
            <textarea name="message" rows="8" required></textarea>
          </label>

          <button type="submit" class="button-link button-link--primary">
            Send message
          </button>
        </form>
      </section>
    </section>
  </div>
</BaseLayout>
