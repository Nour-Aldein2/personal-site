---
import { getCollection } from "astro:content";
import ArticleCard from "../components/ArticleCard.astro";
import ProjectCard from "../components/ProjectCard.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { sortArticles } from "../lib/articles";
import { featuredProjects } from "../lib/projects";
import { absoluteSiteUrl, sitePath, siteSettings } from "../lib/site";

const articles = sortArticles(
  await getCollection("articles", ({ data }) => !data.draft),
);

const featuredArticles = articles.filter((entry) => entry.data.featured).slice(0, 3);

const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: siteSettings.authorName,
  alternateName: siteSettings.alternateNames,
  jobTitle: siteSettings.authorRole,
  description: siteSettings.siteDescription,
  image: absoluteSiteUrl(siteSettings.authorImage, Astro.site),
  url: absoluteSiteUrl("/", Astro.site),
  sameAs: siteSettings.sameAs,
  knowsAbout: [
    "Artificial intelligence",
    "Machine learning",
    "Natural language processing",
    "Model explainability",
    "Technical writing",
    "Astrophysics",
  ],
  homeLocation: {
    "@type": "Place",
    name: siteSettings.location,
  },
};
---

<BaseLayout
  title={`${siteSettings.authorName} | AI Engineer/Researcher`}
  description={siteSettings.siteDescription}
  canonicalPath="/"
  ogType="profile"
  image={siteSettings.authorImage}
  schema={personSchema}
>
  <div class="shell">
    <section class="hero">
      <div class="hero-card">
        <p class="eyebrow">Portfolio</p>
        <h1>{siteSettings.authorName}</h1>
        <p>
          I am an AI/ML engineer and researcher with an MSc in AI (Distinction)
          from the University of Bath and over four years of experience across academia and industry.
          I am specialising in reinforcement learning, computer vision, and statistical modelling,
          applying them to projects like generative modelling for stroke-ordered drawing and
          chemical recipe optimisation (e.g. for MXene).
        </p>
        <p>
          My broader technical interests span MLOps, control and optimisation, reinforcement learning,
          quantitative analysis, natural language processing, computer vision, and computer graphics.
          This site showcases some examples of my end-to-end ML work and research, demonstrating
          my skills and interests across the diverse fields I am working on.
        </p>
        <!--<div class="button-row">-->
        <!--  <a-->
        <!--    href={sitePath(siteSettings.cvFilePath)}-->
        <!--    class="button-link button-link&#45;&#45;primary"-->
        <!--    target="_blank"-->
        <!--    rel="noopener"-->
        <!--  >-->
        <!--    View CV-->
        <!--  </a>-->
        <!--  <a href={sitePath("articles/")} class="button-link button-link&#45;&#45;secondary">-->
        <!--    Read Articles-->
        <!--  </a>-->
        <!--</div>-->
      </div>

      <aside class="profile-panel">
        <img
          src={sitePath(siteSettings.authorImage)}
          alt={siteSettings.authorName}
        />
        <div class="profile-panel__meta">
          <p class="eyebrow">Profiles</p>
          <div class="profile-links">
            <a
              class="profile-link profile-link--icon"
              href={siteSettings.sameAs[0]}
              rel="me noopener noreferrer"
              target="_blank"
              aria-label="GitHub"
            >
              <i class="fa-brands fa-github" aria-hidden="true"></i>
              <span class="sr-only">GitHub</span>
            </a>
            <a
              class="profile-link profile-link--icon"
              href={siteSettings.sameAs[1]}
              rel="me noopener noreferrer"
              target="_blank"
              aria-label="LinkedIn"
            >
              <i class="fa-brands fa-linkedin-in" aria-hidden="true"></i>
              <span class="sr-only">LinkedIn</span>
            </a>
            <a
              class="profile-link profile-link--icon"
              href={siteSettings.contactHref}
              aria-label="Contact"
            >
              <i class="fa-regular fa-envelope" aria-hidden="true"></i>
              <span class="sr-only">Contact</span>
            </a>
          </div>
        </div>
      </aside>
    </section>

    <section class="page-section">
      <div class="section-heading section-heading--wide">
        <p class="eyebrow">Writing</p>
        <h2>Selected articles and case studies</h2>
        <p>
          Selected writing and technical case studies, including the current published
          post on model explainability with BERT and LIME.
        </p>
      </div>
      <div class="article-index-grid">
        {featuredArticles.map((article) => (
          <ArticleCard article={article} />
        ))}
      </div>
    </section>

    <section class="page-section">
      <div class="section-heading section-heading--wide">
        <p class="eyebrow">Projects</p>
        <h2>Selected machine learning and research projects</h2>
        <p>
          A compact view of applied machine learning, computer vision, and
          research-oriented work drawn from the broader portfolio.
        </p>
      </div>
      <div class="project-grid">
        {featuredProjects.map((project) => (
          <ProjectCard project={project} />
        ))}
      </div>
    </section>
  </div>
</BaseLayout>
